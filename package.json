{
  "name": "simple-agent",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "simple-agent": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');const f='dist/index.js';const c=fs.readFileSync(f,'utf8');fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)\" && chmod +x dist/index.js",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "prod": "npm run build && node dist/index.js",
    "link": "npm run build && npm link"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "openai": "^4.73.0"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
